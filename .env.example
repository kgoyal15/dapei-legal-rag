OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Optional: use OpenAI for embeddings (text-embedding-3-small) or local sentence-transformers
EMBEDDING_PROVIDER=openai          # openai | local
EMBEDDING_MODEL=text-embedding-3-small

# LLM used for definition extraction fallback and QA evaluation
LLM_MODEL=gpt-4o-mini

# Where contracts are stored after download
DATA_DIR=./data
